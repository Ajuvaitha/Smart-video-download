{
  "manifest_version": 3,
  "name": "Smart Video Downloader",
  "version": "1.0",
  "description": "Detects and downloads video files from web pages (Educational Purpose).",
  "icons": {
    "128": "icon.svg"
  },
  "permissions": [
    "webRequest",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Video Downloader"
  }
}